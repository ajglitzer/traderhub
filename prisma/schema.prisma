// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Trade {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Core fields
  ticker         String
  assetClass     String   @default("STOCK") // STOCK, FUTURES, CRYPTO, FOREX, OPTIONS, ETF
  side           String   // LONG, SHORT
  status         String   @default("OPEN") // OPEN, CLOSED

  // Execution
  entryPrice     Float
  exitPrice      Float?
  quantity       Float
  entryTime      DateTime
  exitTime       DateTime?

  // Costs
  fees           Float    @default(0)
  commissions    Float    @default(0)

  // Calculated (stored for perf)
  grossPnl       Float?
  netPnl         Float?
  rMultiple      Float?
  riskReward     Float?
  holdTimeSeconds Int?

  // Risk
  stopLoss       Float?
  takeProfit     Float?
  riskAmount     Float?

  // Metadata
  strategy       String?
  setup          String?
  timeframe      String?
  notes          String?
  emotions       String?  // JSON array of emotion tags
  tags           String?  // JSON array of tags
  rating         Int?     // 1-5
  favorite       Boolean  @default(false)
  reviewLater    Boolean  @default(false)
  screenshots    String?  // JSON array of URLs

  // Custom fields
  customFields   String?  // JSON object

  // Relations
  userId         String   @default("local")
  importId       String?  // Which import batch

  @@index([ticker])
  @@index([entryTime])
  @@index([userId])
  @@index([strategy])
  @@index([assetClass])
}

model Import {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  source      String   // TRADINGVIEW, WEBULL, IBKR, NINJATRADER, GENERIC, etc.
  filename    String
  tradeCount  Int
  status      String   @default("COMPLETE")
  userId      String   @default("local")
}

model Watchlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  symbols   String   // JSON array of symbols
  userId    String   @default("local")
}

model JournalEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  date      DateTime
  content   String
  mood      String?
  tags      String?
  userId    String   @default("local")
}

model Settings {
  id         String @id @default(cuid())
  userId     String @unique @default("local")
  theme      String @default("dark")
  accentColor String @default("cyan")
  preferences String @default("{}") // JSON
}
